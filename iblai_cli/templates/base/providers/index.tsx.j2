"use client";
{% raw %}
/**
 * Application providers — AuthProvider + TenantProvider.
 *
 * TenantProvider is required to fetch dm_token and axd_token for the
 * tenant, which the mentor-ai iframe needs to authenticate API calls.
 * A 15-second timeout and onAuthFailure handler prevent it from hanging.
 */

import { useCallback, useEffect, useMemo, useState, type ReactNode } from "react";
import { usePathname } from "next/navigation";
import { initializeDataLayer } from "@iblai/iblai-js/data-layer";
import { AuthProvider, TenantProvider } from "@iblai/iblai-js/web-utils";
import { config } from "@/lib/config";

// ---------------------------------------------------------------------------
// LocalStorageService for initializeDataLayer
// ---------------------------------------------------------------------------

class LocalStorageService {
  private static instance: LocalStorageService;
  static getInstance() {
    if (!this.instance) this.instance = new LocalStorageService();
    return this.instance;
  }
  async getItem<T>(key: string): Promise<T | null> {
    if (typeof window === "undefined") return null;
    return window.localStorage.getItem(key) as T;
  }
  async setItem<T>(key: string, item: T): Promise<void> {
    if (typeof window === "undefined") return;
    window.localStorage.setItem(key, item as unknown as string);
  }
  async removeItem(key: string): Promise<void> {
    if (typeof window === "undefined") return;
    window.localStorage.removeItem(key);
  }
}

const storageService = LocalStorageService.getInstance();

// ---------------------------------------------------------------------------
// Helpers
// ---------------------------------------------------------------------------

function redirectToAuthSpa(
  redirectTo?: string,
  platformKey?: string,
  logout?: boolean,
  saveRedirect?: boolean,
) {
  const origin = typeof window !== "undefined" ? window.location.origin : "";
  const path = redirectTo ?? (typeof window !== "undefined" ? window.location.pathname : "/");
  if (saveRedirect) localStorage.setItem("redirect-to", path);

  const params = new URLSearchParams({ "redirect-to": origin, app: "agent" });
  if (platformKey) params.set("tenant", platformKey);
  if (logout) params.set("logout", "1");

  window.location.href = `${config.authUrl()}/login?${params.toString()}`;
}

function hasNonExpiredAuthToken(): boolean {
  const token = window.localStorage.getItem("axd_token");
  if (!token) return false;
  const tokenExpiry = window.localStorage.getItem("axd_token_expires");
  if (!tokenExpiry) return false;
  return new Date(tokenExpiry) > new Date();
}

const resolveTenantKey = (raw: string | null): string => {
  if (!raw || raw === "[object Object]") return "";
  try {
    const p = JSON.parse(raw);
    if (typeof p === "string") return p;
    if (p?.key) return p.key;
  } catch { /* plain string */ }
  return raw;
};

// Routes that skip auth
const PUBLIC_ROUTES = new Map<RegExp, () => Promise<boolean>>([
  [new RegExp("^/sso-login"), async () => false],
]);

const LOADING = (
  <div className="flex min-h-screen items-center justify-center">
    <p className="text-sm text-gray-400">Loading…</p>
  </div>
);

// ---------------------------------------------------------------------------
// Provider component
// ---------------------------------------------------------------------------

export function Providers({ children }: { children: ReactNode }) {
  const pathname = usePathname();
  const [isInitialized, setIsInitialized] = useState(false);
  // skipTenant becomes true after a 15-second timeout or on auth failure,
  // preventing TenantProvider from blocking the app indefinitely.
  const [skipTenant, setSkipTenant] = useState(false);

  useEffect(() => {
    if (typeof window === "undefined") return;
    try {
      initializeDataLayer(
        config.dmUrl(),
        config.lmsUrl(),
        storageService,
        {
          401: () => redirectToAuthSpa(undefined, undefined, true),
        },
      );
    } catch (e) {
      console.error("[IBL] initializeDataLayer failed:", e);
    }
    setIsInitialized(true);
  }, []);

  // Safety timeout — if TenantProvider hasn't resolved in 15s, skip it
  useEffect(() => {
    const t = setTimeout(() => setSkipTenant(true), 15_000);
    return () => clearTimeout(t);
  }, []);

  const username = useMemo(() => {
    if (typeof window === "undefined") return "";
    try {
      const raw = localStorage.getItem("userData");
      if (raw) return JSON.parse(raw).user_nicename ?? "";
    } catch { /* ignore */ }
    return "";
  }, [isInitialized]);

  const tenantKey = useMemo(() => {
    if (typeof window === "undefined") return "";
    return resolveTenantKey(
      localStorage.getItem("current_tenant") ?? localStorage.getItem("tenant"),
    ) || config.mainTenantKey();
  }, [isInitialized]);

  const saveCurrentTenant = useCallback((t: any) => {
    const key = typeof t === "string" ? t : t?.key ?? String(t);
    localStorage.setItem("current_tenant", key);
    localStorage.setItem("tenant", key);
  }, []);

  const saveUserTenants = useCallback((tenants: any[]) => {
    localStorage.setItem("tenants", JSON.stringify(tenants));
  }, []);

  // saveUserTokens stores the dm_token and axd_token that the mentor-ai
  // iframe needs to authenticate its API calls.
  const saveUserTokens = useCallback((tokens: any) => {
    if (!tokens) return;
    const dm = tokens.dm_token ?? tokens;
    const axd = tokens.axd_token ?? tokens;
    if (dm?.token) {
      localStorage.setItem("dm_token", dm.token);
      localStorage.setItem("dm_token_expires", dm.expires ?? "");
    }
    if (axd?.token) {
      localStorage.setItem("axd_token", axd.token);
      localStorage.setItem("axd_token_expires", axd.expires ?? "");
    }
  }, []);

  const saveTenant = useCallback((t: string) => {
    const key = typeof t === "string" ? t : (t as any)?.key ?? String(t);
    localStorage.setItem("tenant", key);
  }, []);

  const handleTenantSwitch = useCallback(async (t: any) => {
    // Update tenant in localStorage and reload — do NOT redirect to auth SPA.
    const key = typeof t === "string" ? t : t?.key ?? String(t);
    if (key) {
      localStorage.setItem("current_tenant", key);
      localStorage.setItem("tenant", key);
    }
    window.location.reload();
  }, []);

  const isSsoRoute = pathname?.startsWith("/sso-login") ?? false;

  if (!isInitialized) {
    return LOADING;
  }

  return (
    <AuthProvider
      skip={isSsoRoute}
      redirectToAuthSpa={redirectToAuthSpa}
      hasNonExpiredAuthToken={hasNonExpiredAuthToken}
      username={username}
      pathname={pathname ?? "/"}
      storageService={storageService}
      middleware={PUBLIC_ROUTES}
      enableStorageSync
      fallback={
        <div className="flex min-h-screen items-center justify-center">
          <p className="text-sm text-gray-400">Authenticating…</p>
        </div>
      }
    >
      <TenantProvider
        skip={isSsoRoute || skipTenant}
        currentTenant={tenantKey}
        requestedTenant={tenantKey}
        saveCurrentTenant={saveCurrentTenant}
        saveUserTenants={saveUserTenants}
        saveUserTokens={saveUserTokens}
        saveTenant={saveTenant}
        handleTenantSwitch={handleTenantSwitch}
        redirectToAuthSpa={
          // Suppress TenantProvider's own auth redirect — the host AuthProvider
          // manages top-level auth. TenantProvider redirecting with redirect-token=null
          // causes a 409 "Unknown site" error in the auth SPA.
          () => { console.warn("[TenantProvider] auth redirect suppressed"); setSkipTenant(true); }
        }
        username={username}
        fallback={LOADING}
        onAuthFailure={(reason) => {
          console.error("[TenantProvider] auth failure:", reason);
          setSkipTenant(true);
        }}
      >
        {children}
      </TenantProvider>
    </AuthProvider>
  );
}
