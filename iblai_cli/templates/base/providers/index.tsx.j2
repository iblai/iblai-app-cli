"use client";
{% raw %}
/**
 * Application providers — AuthProvider only.
 *
 * Before rendering children, fetches the user's tenant list from the LMS API
 * and stores it in localStorage so the ChatWidget's ibl-data includes the
 * correct tenants value the MentorAI iframe needs for chat session access.
 */

import { useEffect, useMemo, useState, type ReactNode } from "react";
import { usePathname } from "next/navigation";
import { initializeDataLayer } from "@iblai/iblai-js/data-layer";
import { AuthProvider } from "@iblai/iblai-js/web-utils";
import { config } from "@/lib/config";

// ---------------------------------------------------------------------------
// LocalStorageService for initializeDataLayer
// ---------------------------------------------------------------------------

class LocalStorageService {
  private static instance: LocalStorageService;
  static getInstance() {
    if (!this.instance) this.instance = new LocalStorageService();
    return this.instance;
  }
  async getItem<T>(key: string): Promise<T | null> {
    if (typeof window === "undefined") return null;
    return window.localStorage.getItem(key) as T;
  }
  async setItem<T>(key: string, item: T): Promise<void> {
    if (typeof window === "undefined") return;
    window.localStorage.setItem(key, item as unknown as string);
  }
  async removeItem(key: string): Promise<void> {
    if (typeof window === "undefined") return;
    window.localStorage.removeItem(key);
  }
}

const storageService = LocalStorageService.getInstance();

// ---------------------------------------------------------------------------
// Helpers
// ---------------------------------------------------------------------------

function redirectToAuthSpa(
  redirectTo?: string,
  platformKey?: string,
  logout?: boolean,
  saveRedirect?: boolean,
) {
  const origin = typeof window !== "undefined" ? window.location.origin : "";
  const path = redirectTo ?? (typeof window !== "undefined" ? window.location.pathname : "/");
  if (saveRedirect) localStorage.setItem("redirect-to", path);

  const params = new URLSearchParams({ "redirect-to": origin, app: "agent" });
  if (platformKey) params.set("tenant", platformKey);
  if (logout) params.set("logout", "1");

  window.location.href = `${config.authUrl()}/login?${params.toString()}`;
}

function hasNonExpiredAuthToken(): boolean {
  const token = window.localStorage.getItem("axd_token");
  if (!token) return false;
  const tokenExpiry = window.localStorage.getItem("axd_token_expires");
  if (!tokenExpiry) return false;
  return new Date(tokenExpiry) > new Date();
}

// Routes that skip auth
const PUBLIC_ROUTES = new Map<RegExp, () => Promise<boolean>>([
  [new RegExp("^/sso-login"), async () => false],
]);

const LOADING = (
  <div className="flex min-h-screen items-center justify-center">
    <p className="text-sm text-gray-400">Loading…</p>
  </div>
);

// ---------------------------------------------------------------------------
// Provider component
// ---------------------------------------------------------------------------

export function Providers({ children }: { children: ReactNode }) {
  const pathname = usePathname();
  const [isInitialized, setIsInitialized] = useState(false);
  // tenantsReady gates rendering children so the ChatWidget always receives
  // a populated tenants list in its ibl-data URL parameter.
  const [tenantsReady, setTenantsReady] = useState(false);

  useEffect(() => {
    if (typeof window === "undefined") return;

    // initialise the data layer (RTK Query API configuration)
    try {
      initializeDataLayer(
        config.dmUrl(),
        config.lmsUrl(),
        storageService,
        {
          401: () => redirectToAuthSpa(undefined, undefined, true),
        },
      );
    } catch (e) {
      console.error("[IBL] initializeDataLayer failed:", e);
    }
    setIsInitialized(true);

    // Fetch the tenant list from the LMS API if not already in localStorage.
    // The ChatWidget's ibl-data must include tenants so the MentorAI iframe
    // can create an authenticated chat session.
    const existingTenants = localStorage.getItem("tenants");
    const needsTenants =
      !existingTenants ||
      existingTenants === "[]" ||
      existingTenants === "null";

    if (!needsTenants) {
      setTenantsReady(true);
      return;
    }

    const edxToken = localStorage.getItem("edx_jwt_token");
    if (!edxToken) {
      // No token yet (pre-auth) — render anyway and let AuthProvider redirect.
      setTenantsReady(true);
      return;
    }

    // Safety timeout — don't block forever if the fetch hangs.
    const safety = setTimeout(() => {
      console.warn("[IBL] Tenant fetch timed out after 15s");
      setTenantsReady(true);
    }, 15_000);

    fetch(`${config.lmsUrl()}/api/ibl/users/manage/platform/`, {
      headers: { Authorization: `JWT ${edxToken}` },
    })
      .then((res) => (res.ok ? res.json() : Promise.reject(res.status)))
      .then((data) => {
        localStorage.setItem("tenants", JSON.stringify(data));
      })
      .catch((err) => {
        console.warn("[IBL] Failed to fetch tenants:", err);
      })
      .finally(() => {
        clearTimeout(safety);
        setTenantsReady(true);
      });

    return () => clearTimeout(safety);
  }, []);

  const username = useMemo(() => {
    if (typeof window === "undefined") return "";
    try {
      const raw = localStorage.getItem("userData");
      if (raw) return JSON.parse(raw).user_nicename ?? "";
    } catch { /* ignore */ }
    return "";
  }, [isInitialized]);

  const isSsoRoute = pathname?.startsWith("/sso-login") ?? false;

  if (!isInitialized) {
    return LOADING;
  }

  return (
    <AuthProvider
      skip={isSsoRoute}
      redirectToAuthSpa={redirectToAuthSpa}
      hasNonExpiredAuthToken={hasNonExpiredAuthToken}
      username={username}
      pathname={pathname ?? "/"}
      storageService={storageService}
      middleware={PUBLIC_ROUTES}
      enableStorageSync
      fallback={
        <div className="flex min-h-screen items-center justify-center">
          <p className="text-sm text-gray-400">Authenticating…</p>
        </div>
      }
    >
      {tenantsReady ? children : LOADING}
    </AuthProvider>
  );
}
