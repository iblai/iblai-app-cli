{% raw %}'use client';

import ReactMarkdown from 'react-markdown';
import remarkGfm from 'remark-gfm';
import { cn } from '@/lib/utils';

type Props = {
  children?: string;
  className?: string;
};

export default function Markdown({ children, className }: Props) {
  return (
    <div className={cn('space-y-4', className)}>
      <ReactMarkdown
        remarkPlugins={[remarkGfm]}
        components={{
          a: ({ node, ...props }) => (
            <a
              className="text-blue-500 underline"
              target="_blank"
              rel="noopener noreferrer"
              {...props}
            />
          ),
          table: ({ node, ...props }) => (
            <div className="my-6 w-full overflow-x-auto">
              <table {...props} className="w-full border-collapse" />
            </div>
          ),
          tr: ({ node, ...props }) => (
            <tr
              {...props}
              className="even:bg-muted even:text-gray-700 m-0 border-t p-0"
            />
          ),
          th: ({ node, ...props }) => (
            <th
              {...props}
              className="border px-4 py-2 text-left font-bold whitespace-nowrap"
            />
          ),
          td: ({ node, ...props }) => (
            <td {...props} className="border px-4 py-2 text-left" />
          ),
          pre: ({ node, ...props }) => (
            <pre {...props} className="bg-gray-200 w-full overflow-x-auto p-2 rounded" />
          ),
          code: ({ node, className: codeClassName, ...props }) => {
            const isBlock = /language-(\w+)/.test(codeClassName || '');
            if (isBlock) {
              return (
                <code {...props} className={codeClassName} />
              );
            }
            return (
              <code
                {...props}
                className="relative rounded px-[0.3rem] py-[0.2rem] font-mono text-sm bg-gray-200"
              />
            );
          },
        }}
      >
        {children ?? ''}
      </ReactMarkdown>
    </div>
  );
}
{% endraw %}