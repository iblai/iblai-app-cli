"use client";

import {
  Sidebar,
  SidebarContent,
  SidebarFooter,
  SidebarHeader,
  SidebarMenu,
  SidebarMenuItem,
  SidebarMenuButton,
  useSidebar,
} from "@/components/ui/sidebar";
import {
  PenSquare,
  PanelLeft,
  MessageCircle,
  MessageCircleIcon,
  MoreHorizontal,
  Trash2,
  ChevronRight,
} from "lucide-react";
import { useParams } from "next/navigation";
import { Button } from "@/components/ui/button";
import {
  Tooltip,
  TooltipContent,
  TooltipTrigger,
} from "@/components/ui/tooltip";
import {
  DropdownMenu,
  DropdownMenuContent,
  DropdownMenuItem,
  DropdownMenuTrigger,
} from "@/components/ui/dropdown-menu";
import { cn } from "@/lib/utils";
import {
  useGetMentorPublicSettingsQuery,
  useGetRecentMessageQuery,
  useDeleteMessageMutation,
  chatApiSlice,
} from "@iblai/iblai-js/data-layer";
import {
  chatActions,
  selectSessionId,
  selectStreaming,
  selectActiveChatMessages,
  clearFiles,
} from "@iblai/iblai-js/web-utils";
import { useUsername } from "@/hooks/use-user";
import { useAppDispatch, useAppSelector } from "@/lib/hooks";
import { config } from "@/lib/config";
import Image from "next/image";
import React, { useState, useEffect, useCallback } from "react";

const SESSION_CACHE_KEY = "agent_cached_session_ids";

function getFirstMessageContent(messages: any[]): string {
  if (!messages?.length) return "No content";
  // Find first human message with content
  for (const msg of messages) {
    if (msg?.message?.type === "human" && msg?.message?.data?.content) {
      return msg.message.data.content;
    }
  }
  // Fall back to first message with any content
  for (const msg of messages) {
    if (msg?.message?.data?.content) {
      return msg.message.data.content;
    }
  }
  return "No content";
}

export function AppSidebar() {
  const params = useParams();
  const dispatch = useAppDispatch();
  const tenantKey = params.tenantKey as string;
  const agentId = params.agentId as string;
  const username = useUsername();
  const { toggleSidebar, open, openMobile, isMobile, setOpenMobile } =
    useSidebar();
  const [logoError, setLogoError] = useState(false);
  const [recentOpen, setRecentOpen] = useState(true);

  const isSidebarOpen = (isMobile && openMobile) || (!isMobile && open);

  const appSessionId = useAppSelector(selectSessionId);
  const isStreaming = useAppSelector(selectStreaming);
  const activeChatMessages = useAppSelector(selectActiveChatMessages);
  const numberOfActiveChatMessages = activeChatMessages?.length ?? 0;

  const { data: mentorPublicSettings } = useGetMentorPublicSettingsQuery(
    {
      mentor: agentId,
      org: tenantKey,
      // @ts-ignore
      userId: username ?? "anonymous",
    },
    {
      skip: !agentId || !tenantKey,
    }
  );

  const mentorName = mentorPublicSettings?.mentor || "Agent";

  const {
    data: recentMessages,
    refetch: refetchRecentMessages,
  } = useGetRecentMessageQuery(
    {
      org: tenantKey,
      // @ts-ignore
      userId: username,
    },
    {
      skip: !username || username === "anonymous" || !tenantKey,
      selectFromResult(state) {
        return {
          ...state,
          data: {
            ...state.data,
            results: state.data?.results?.filter(
              (result: any) => result.mentor.unique_id === agentId
            ),
          },
        };
      },
    }
  );

  const [deleteMessage] = useDeleteMessageMutation();

  // Auto-refetch recent messages when a new chat gets its first AI response
  useEffect(() => {
    if (
      username &&
      username !== "anonymous" &&
      !isStreaming &&
      numberOfActiveChatMessages === 2 &&
      activeChatMessages?.[1]?.role === "assistant"
    ) {
      refetchRecentMessages();
    }
  }, [
    isStreaming,
    numberOfActiveChatMessages,
    refetchRecentMessages,
    activeChatMessages,
    username,
  ]);

  const handleNewChat = useCallback(() => {
    dispatch(clearFiles(undefined));
    dispatch(chatActions.setShouldStartNewChat(true));
    // Clear cached session for this mentor
    try {
      const cached = JSON.parse(
        localStorage.getItem(SESSION_CACHE_KEY) || "{}"
      );
      delete cached[agentId];
      localStorage.setItem(SESSION_CACHE_KEY, JSON.stringify(cached));
    } catch {
      // ignore
    }
    if (isMobile) setOpenMobile(false);
  }, [dispatch, agentId, isMobile, setOpenMobile]);

  const handleSelectMessage = useCallback(
    (message: any) => {
      // Clear files if session is different
      if (message.session_id !== appSessionId) {
        dispatch(clearFiles(undefined));
      }

      const messages = message.messages
        .map((messageObj: any) => {
          const fileAttachments =
            messageObj.files?.map((file: any) => ({
              fileId: String(file.id),
              fileName: file.name,
              fileType: file.content_type,
              fileSize: file.file_size,
              uploadUrl: file.url,
            })) || [];

          return {
            id: messageObj.id,
            role: messageObj.message.type === "human" ? "user" : "ai",
            content: messageObj.message.data.content,
            timestamp: messageObj.inserted_at,
            visible: true,
            fileAttachments:
              fileAttachments.length > 0 ? fileAttachments : undefined,
          };
        })
        .reverse();

      dispatch(chatActions.resetIsTyping(undefined));
      dispatch(chatActions.setStreaming(false));
      dispatch(chatActions.resetCurrentStreamingMessage(undefined));
      dispatch(chatActions.setActiveTab("chat"));
      dispatch(chatActions.updateSessionIds(message.session_id));
      dispatch(chatActions.setNewMessages(messages));
      dispatch(chatActions.setShouldStartNewChat(false));

      // Persist session ID to localStorage
      try {
        const cached = JSON.parse(
          localStorage.getItem(SESSION_CACHE_KEY) || "{}"
        );
        cached[agentId] = message.session_id;
        localStorage.setItem(SESSION_CACHE_KEY, JSON.stringify(cached));
      } catch {
        // ignore
      }

      if (isMobile) setOpenMobile(false);
    },
    [dispatch, appSessionId, agentId, isMobile, setOpenMobile]
  );

  const handleDeleteMessage = useCallback(
    async (recentMessage: any) => {
      try {
        await deleteMessage({
          org: tenantKey,
          // @ts-ignore
          userId: username,
          sessionId: recentMessage.session_id,
        }).unwrap();

        // Remove from recent messages cache
        (dispatch as any)(
          chatApiSlice.util.updateQueryData(
            "getRecentMessage",
            {
              org: tenantKey,
              // @ts-ignore
              userId: username,
            },
            (draft: any) => {
              draft.results = draft.results.filter(
                (msg: any) => msg.session_id !== recentMessage.session_id
              );
            }
          )
        );

        // If the deleted session was the active chat, start a new chat
        if (recentMessage.session_id === appSessionId) {
          dispatch(clearFiles(undefined));
          dispatch(chatActions.setShouldStartNewChat(true));
        }
      } catch (err) {
        console.error("Failed to delete message: ", err);
      }
    },
    [dispatch, tenantKey, username, appSessionId, deleteMessage]
  );

  const logoUrl = `${config.axdUrl()}/api/core/orgs/${tenantKey}/logo/`;

  return (
    <Sidebar
      collapsible="icon"
      variant="sidebar"
      className="flex flex-col border-r border-[#D0E0FF] transition-all duration-300 bg-white"
    >
      <SidebarHeader className="h-16 flex justify-center flex-none border-b border-[#D0E0FF]">
        <div
          className={cn("flex w-full items-center", {
            "justify-center": !isSidebarOpen,
          })}
        >
          <Button
            data-sidebar="trigger"
            variant="ghost"
            size="icon"
            onClick={toggleSidebar}
            className="h-7 w-7 z-10"
          >
            <PanelLeft className="h-5 w-5" />
            <span className="sr-only">
              {isSidebarOpen ? "Close sidebar" : "Open sidebar"}
            </span>
          </Button>
          {isSidebarOpen && (
            <div className="-ml-9 flex-1 flex items-center justify-center">
              {!logoError ? (
                <Image
                  src={logoUrl}
                  alt="Logo"
                  width={160}
                  height={50}
                  className="max-h-[50px] w-auto object-contain"
                  onError={() => setLogoError(true)}
                  unoptimized
                />
              ) : (
                <span className="font-semibold text-lg text-gray-800">
                  {mentorName}
                </span>
              )}
            </div>
          )}
        </div>
      </SidebarHeader>

      <SidebarContent className="!overflow-visible p-4 flex-grow px-0">
        <SidebarMenu
          className={cn("flex-none px-4 gap-0", {
            "place-content-center": !open && !openMobile,
          })}
        >
          {/* New Chat button */}
          <SidebarMenuItem className="font-medium">
            {isSidebarOpen ? (
              <SidebarMenuButton
                asChild
                className="cursor-pointer space-x-1 mb-1 text-gray-700 border border-[#c9d8f8] py-4 h-9"
              >
                <button onClick={handleNewChat}>
                  <PenSquare className="h-5 w-5 text-gray-500" />
                  <span>New Chat</span>
                </button>
              </SidebarMenuButton>
            ) : (
              <Tooltip>
                <TooltipTrigger asChild>
                  <SidebarMenuButton
                    asChild
                    className="cursor-pointer mb-1 text-gray-700 hover:bg-[#c9d8f8] justify-center"
                  >
                    <button onClick={handleNewChat}>
                      <PenSquare className="h-5 w-5 text-gray-500" />
                    </button>
                  </SidebarMenuButton>
                </TooltipTrigger>
                <TooltipContent side="right">New Chat</TooltipContent>
              </Tooltip>
            )}
          </SidebarMenuItem>
        </SidebarMenu>

        <div className="border-t border-[#D0E0FF] mb-2" />

        {/* Recent Messages */}
        <SidebarMenu className="flex-1 overflow-auto h-full scrollbar-thin px-4">
          <SidebarMenuItem className="overflow-y-auto h-full scrollbar-thin">
            {isSidebarOpen && recentMessages?.results?.length ? (
              <div className="flex max-h-fit flex-col overflow-y-auto">
                <button
                  onClick={() => setRecentOpen(!recentOpen)}
                  className="flex items-center gap-3 text-sm font-medium py-1.5 px-2 text-gray-700 hover:bg-[#c9d8f8] rounded-md cursor-pointer"
                >
                  <ChevronRight
                    className={cn(
                      "h-4 w-4 text-gray-500 transition-transform",
                      recentOpen && "rotate-90"
                    )}
                  />
                  <MessageCircle className="h-4 w-4 text-gray-500" />
                  <span>Recent</span>
                </button>

                {recentOpen && (
                  <div className="space-y-1 border-l border-[#D0E0FF] ml-4 mt-1">
                    {recentMessages.results.map((result: any) => (
                      <div
                        className="group relative"
                        key={result?.session_id}
                      >
                        <Button
                          variant="ghost"
                          className={cn(
                            "flex h-auto w-full items-center gap-1 px-2 hover:bg-[#c9d8f8]",
                            {
                              "bg-[#c9d8f8]":
                                appSessionId === result.session_id,
                            }
                          )}
                          onClick={() => handleSelectMessage(result)}
                        >
                          <div className="mr-2 flex h-4 w-4 flex-shrink-0 items-center justify-center overflow-hidden rounded-full bg-gray-300 text-xs">
                            {result?.mentor?.profile_image ? (
                              <Image
                                src={result.mentor.profile_image}
                                alt="Mentor avatar"
                                className="h-full w-full object-cover"
                                width={20}
                                height={20}
                              />
                            ) : (
                              <MessageCircleIcon className="h-3 w-3" />
                            )}
                          </div>
                          <div className="line-clamp-1 flex-1 overflow-hidden pr-6 text-left text-xs text-gray-800">
                            {getFirstMessageContent(result.messages)}
                          </div>
                        </Button>
                        <div className="absolute top-1/2 right-2 -translate-y-1/2 opacity-0 transition-opacity group-hover:opacity-100">
                          <DropdownMenu>
                            <DropdownMenuTrigger asChild>
                              <Button
                                variant="ghost"
                                size="icon"
                                className="h-6 w-6 p-0"
                              >
                                <span className="sr-only">
                                  More chat options
                                </span>
                                <MoreHorizontal className="h-4 w-4 text-gray-400" />
                              </Button>
                            </DropdownMenuTrigger>
                            <DropdownMenuContent align="end">
                              <DropdownMenuItem
                                onClick={() => handleDeleteMessage(result)}
                              >
                                <Trash2 className="mr-2 h-4 w-4" />
                                <span>Delete</span>
                              </DropdownMenuItem>
                            </DropdownMenuContent>
                          </DropdownMenu>
                        </div>
                      </div>
                    ))}
                  </div>
                )}
              </div>
            ) : null}
          </SidebarMenuItem>
        </SidebarMenu>
      </SidebarContent>

      <div className="border-t border-[#D0E0FF] mb-2" />
      <SidebarFooter className="flex-none px-0">
        <SidebarMenu className="px-4">
          <SidebarMenuItem>
            <div className="px-2 py-2 text-xs text-gray-500">
              Powered by IBL.ai
            </div>
          </SidebarMenuItem>
        </SidebarMenu>
      </SidebarFooter>
    </Sidebar>
  );
}
