{% raw %}'use client';

import React, { useState } from 'react';
import {
  Copy,
  ThumbsUp,
  ThumbsDown,
  Share2,
  RefreshCcw,
  Loader2,
} from 'lucide-react';
import { toast } from 'sonner';
import { Avatar, AvatarFallback, AvatarImage } from '@/components/ui/avatar';
import {
  Tooltip,
  TooltipContent,
  TooltipTrigger,
  TooltipProvider,
} from '@/components/ui/tooltip';
import {
  useUpdateMessageFeedbackMutation,
  useUpdateChatSessionSharedMutation,
} from '@iblai/iblai-js/data-layer';
import { useCopyToClipboard } from '@/hooks/use-copy-to-clipboard';
import { useUsername } from '@/hooks/use-user';
import { cn } from '@/lib/utils';
import Markdown from '@/components/markdown';

interface Message {
  id: string;
  role: 'user' | 'assistant' | 'system';
  content: string;
  timestamp?: string;
  visible?: boolean;
}

interface ChatMessagesProps {
  messages: Message[];
  isStreaming?: boolean;
  isPending?: boolean;
  mentorName?: string;
  profileImage?: string;
  sessionId?: string;
  mentorId?: string;
  tenantKey?: string;
  onRetry?: (content: string) => void;
}

function formatTime(timestamp?: string): string {
  if (!timestamp) return '';
  try {
    const date = new Date(timestamp);
    return date.toLocaleTimeString([], {
      hour: 'numeric',
      minute: '2-digit',
    });
  } catch {
    return '';
  }
}

/* ─── Copy Button ─── */
function CopyButton({ content }: { content: string }) {
  const { copy, status } = useCopyToClipboard();
  const isCopied = status === 'success';

  return (
    <Tooltip>
      <TooltipTrigger asChild>
        <button
          onClick={() => copy(content)}
          className="text-gray-500 hover:text-gray-700"
          aria-label="Copy to Clipboard"
        >
          <span className="sr-only">Copy to Clipboard</span>
          {isCopied ? (
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              strokeWidth="2"
              strokeLinecap="round"
              strokeLinejoin="round"
              className="text-blue-500 h-4 w-4"
            >
              <polyline points="20 6 9 17 4 12" />
            </svg>
          ) : (
            <Copy className="h-4 w-4" />
          )}
        </button>
      </TooltipTrigger>
      <TooltipContent className="ibl-tooltip-content">
        {isCopied ? 'Copied' : 'Copy to Clipboard'}
      </TooltipContent>
    </Tooltip>
  );
}

/* ─── Rating Buttons ─── */
function RatingButtons({
  content,
  sessionId,
  mentorId,
  tenantKey,
}: {
  content: string;
  sessionId: string;
  mentorId: string;
  tenantKey: string;
}) {
  const [rating, setRating] = useState<number | null>(null);
  const username = useUsername();
  const [updateMessageFeedback, { isLoading }] =
    useUpdateMessageFeedbackMutation();

  const handleRate = async (value: number) => {
    try {
      await updateMessageFeedback({
        org: tenantKey,
        requestBody: {
          rating: value,
          ai_response: content,
          user_text: '',
          session: sessionId,
          // @ts-expect-error - API expects number but mentorId prop is string
          mentor: mentorId,
          username: username ?? '',
          reason: value === 1 ? 'Good response' : 'Bad response',
          additional_feedback:
            value === 1 ? 'Good response' : 'Bad response',
        },
        userId: username ?? '',
      }).unwrap();
      setRating(value);
    } catch {
      toast.error('Failed to update message feedback');
    }
  };

  return (
    <>
      <Tooltip>
        <TooltipTrigger asChild>
          <button
            type="button"
            disabled={isLoading}
            onClick={() => handleRate(1)}
            className="text-gray-500 hover:text-gray-700 -ml-1"
          >
            <span className="sr-only">Positive Feedback</span>
            <ThumbsUp
              className={cn(
                'h-4 w-4',
                rating === 1 && 'text-gray-400 fill-gray-400 stroke-1',
              )}
            />
          </button>
        </TooltipTrigger>
        <TooltipContent className="ibl-tooltip-content">
          Positive Feedback
        </TooltipContent>
      </Tooltip>
      <Tooltip>
        <TooltipTrigger asChild>
          <button
            type="button"
            disabled={isLoading}
            onClick={() => handleRate(-1)}
            className="text-gray-500 hover:text-gray-700 -ml-1"
          >
            <span className="sr-only">Negative Feedback</span>
            <ThumbsDown
              className={cn(
                'h-4 w-4',
                rating === -1 && 'text-gray-400 fill-gray-400 stroke-1',
              )}
            />
          </button>
        </TooltipTrigger>
        <TooltipContent className="ibl-tooltip-content">
          Negative Feedback
        </TooltipContent>
      </Tooltip>
    </>
  );
}

/* ─── Share Button ─── */
function ShareButton({
  sessionId,
  tenantKey,
}: {
  sessionId: string;
  tenantKey: string;
}) {
  const { copy, status } = useCopyToClipboard();
  const isCopied = status === 'success';
  const username = useUsername();
  const [updateChatSessionShared, { isLoading }] =
    useUpdateChatSessionSharedMutation();

  const handleShare = async () => {
    const shareUrl = `${window.location.origin}/share/chat/${sessionId}`;
    copy(shareUrl);

    try {
      await updateChatSessionShared({
        org: tenantKey,
        sessionId,
        // @ts-ignore - userId is required at runtime but not in generated types
        userId: username ?? 'anonymous',
        requestBody: { is_shared: true },
      }).unwrap();
      toast.success('Share link copied to clipboard');
    } catch {
      toast.error('Failed to share chat');
    }
  };

  return (
    <Tooltip>
      <TooltipTrigger asChild>
        <button
          onClick={handleShare}
          disabled={isLoading}
          className="text-gray-500 hover:text-gray-700 disabled:opacity-50"
        >
          <span className="sr-only">Share this chat</span>
          {isLoading ? (
            <Loader2 className="h-4 w-4 animate-spin" />
          ) : isCopied ? (
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              strokeWidth="2"
              strokeLinecap="round"
              strokeLinejoin="round"
              className="text-blue-500 h-4 w-4"
            >
              <polyline points="20 6 9 17 4 12" />
            </svg>
          ) : (
            <Share2 className="h-4 w-4" />
          )}
        </button>
      </TooltipTrigger>
      <TooltipContent className="ibl-tooltip-content">
        {isLoading ? 'Sharing...' : isCopied ? 'Copied' : 'Share'}
      </TooltipContent>
    </Tooltip>
  );
}

/* ─── Main Component ─── */
export function ChatMessages({
  messages,
  isStreaming,
  isPending,
  mentorName = 'Agent',
  profileImage,
  sessionId,
  mentorId,
  tenantKey,
  onRetry,
}: ChatMessagesProps) {
  const username = useUsername();
  const isLoggedIn = username !== 'anonymous';
  const visibleMessages = messages.filter((m) => m.visible !== false);

  const getLastUserMessage = () => {
    for (let i = visibleMessages.length - 1; i >= 0; i--) {
      if (visibleMessages[i].role === 'user') return visibleMessages[i];
    }
    return null;
  };

  return (
    <TooltipProvider>
      {visibleMessages.map((message, i) =>
        message.role === 'user' ? (
          /* User message: right-aligned bubble */
          <div
            key={`message-${message.id}-${i}`}
            className="flex flex-col items-end mb-4 pl-4"
          >
            <div className="bg-blue-50 text-gray-800 text-sm rounded-lg px-4 py-2 max-w-[80%] whitespace-pre-wrap wrap-anywhere">
              {message.content}
            </div>
          </div>
        ) : (
          /* AI message: avatar + name + timestamp + bubble + action buttons */
          <div key={`message-${message.id}-${i}`} className="mb-4">
            <div className="flex items-start ml-0">
              <div className="shrink-0 mr-2 sm:mr-3">
                <Avatar className="h-7 w-7 sm:h-8 sm:w-8 border border-gray-200 p-[1px] rounded-full">
                  {profileImage ? (
                    <AvatarImage src={profileImage} alt={mentorName} />
                  ) : null}
                  <AvatarFallback className="text-xs font-medium">
                    {mentorName.substring(0, 2).toUpperCase()}
                  </AvatarFallback>
                </Avatar>
              </div>

              <div className="flex-1 min-w-0 max-w-full md:max-w-[75%]">
                <div className="flex items-center mb-1">
                  <span className="font-medium text-gray-900 mr-2 text-sm">
                    {mentorName}
                  </span>
                  {message.timestamp && (
                    <span className="text-gray-500 text-xs">
                      {formatTime(message.timestamp)}
                    </span>
                  )}
                </div>

                <div className="bg-gray-100 rounded-lg p-3 mb-1.5 wrap-anywhere">
                  <div className="text-gray-800 text-sm/6 overflow-x-auto [&_strong]:font-bold [&_em]:italic [&_code]:bg-gray-200 [&_code]:px-1 [&_code]:py-0.5 [&_code]:rounded [&_code]:font-mono [&_pre]:bg-gray-200 [&_pre]:p-2 [&_pre]:rounded [&_pre]:overflow-x-auto [&_ul]:list-disc [&_ul]:pl-4 [&_ol]:list-decimal [&_ol]:pl-4 [&_li]:mb-1">
                    <Markdown>{message.content}</Markdown>
                  </div>
                </div>

                {/* Action buttons */}
                <div className="flex items-center space-x-4">
                  <CopyButton content={message.content} />

                  {isLoggedIn && sessionId && mentorId && tenantKey && (
                    <RatingButtons
                      content={message.content}
                      sessionId={sessionId}
                      mentorId={mentorId}
                      tenantKey={tenantKey}
                    />
                  )}

                  {isLoggedIn && sessionId && tenantKey && (
                    <ShareButton
                      sessionId={sessionId}
                      tenantKey={tenantKey}
                    />
                  )}

                  {isLoggedIn && onRetry && (
                    <Tooltip>
                      <TooltipTrigger asChild>
                        <button
                          onClick={() => {
                            const lastMsg = getLastUserMessage();
                            if (lastMsg) onRetry(lastMsg.content);
                          }}
                          className="text-gray-500 hover:text-gray-700 -ml-1"
                        >
                          <span className="sr-only">Retry</span>
                          <RefreshCcw className="h-4 w-4" />
                        </button>
                      </TooltipTrigger>
                      <TooltipContent className="ibl-tooltip-content">
                        Retry
                      </TooltipContent>
                    </Tooltip>
                  )}
                </div>
              </div>
            </div>
          </div>
        ),
      )}

      {(isPending || isStreaming) &&
        !messages.some(
          (m, i) =>
            i === messages.length - 1 &&
            m.role === 'assistant' &&
            m.content,
        ) && (
        <div className="mb-4">
          <div className="flex items-center ml-0">
            <div className="shrink-0 mr-2 sm:mr-3 relative">
              <div className="absolute inset-0 rounded-full border-2 border-gray-300 border-t-blue-500 animate-spin" />
              <Avatar className="h-7 w-7 sm:h-8 sm:w-8 border border-transparent p-px rounded-full">
                {profileImage ? (
                  <AvatarImage src={profileImage} alt={mentorName} />
                ) : null}
                <AvatarFallback className="text-xs font-medium">
                  {mentorName.substring(0, 2).toUpperCase()}
                </AvatarFallback>
              </Avatar>
            </div>
            <span className="text-gray-700 text-sm">Just a sec...</span>
          </div>
        </div>
      )}
    </TooltipProvider>
  );
}
{% endraw %}
