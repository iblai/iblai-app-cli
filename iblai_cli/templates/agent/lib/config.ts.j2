/**
 * Static env object — Next.js inlines NEXT_PUBLIC_* values at build time
 * only when they appear as literal `process.env.NEXT_PUBLIC_*` references.
 */
const env = {
  NEXT_PUBLIC_AUTH_URL: process.env.NEXT_PUBLIC_AUTH_URL,
  NEXT_PUBLIC_LMS_URL: process.env.NEXT_PUBLIC_LMS_URL,
  NEXT_PUBLIC_DM_URL: process.env.NEXT_PUBLIC_DM_URL,
  NEXT_PUBLIC_AXD_URL: process.env.NEXT_PUBLIC_AXD_URL,
  NEXT_PUBLIC_BASE_WS_URL: process.env.NEXT_PUBLIC_BASE_WS_URL,
  NEXT_PUBLIC_MAIN_TENANT_KEY: process.env.NEXT_PUBLIC_MAIN_TENANT_KEY,
  NEXT_PUBLIC_IBL_PLATFORM: process.env.NEXT_PUBLIC_IBL_PLATFORM,
  NEXT_PUBLIC_AGENT_URL: process.env.NEXT_PUBLIC_AGENT_URL,
  NEXT_PUBLIC_DEFAULT_AGENT_ID: process.env.NEXT_PUBLIC_DEFAULT_AGENT_ID,
  NEXT_PUBLIC_SUPPORT_EMAIL: process.env.NEXT_PUBLIC_SUPPORT_EMAIL,
};

const runtimeEnv = () =>
  typeof window !== "undefined" ? (window as any).__ENV__ || {} : {};

export const getEnv = (key: keyof typeof env, fallback = ""): string => {
  return runtimeEnv()[key] ?? env[key] ?? fallback;
};

/**
 * Application configuration
 * Priority: runtime env (window.__ENV__) → build-time env (process.env) → fallback
 */
export const config = {
  authUrl: () => getEnv("NEXT_PUBLIC_AUTH_URL", "https://login.iblai.app"),
  lmsUrl: () => getEnv("NEXT_PUBLIC_LMS_URL", "https://learn.iblai.app"),
  dmUrl: () => getEnv("NEXT_PUBLIC_DM_URL", "https://base.manager.iblai.app"),
  axdUrl: () => getEnv("NEXT_PUBLIC_AXD_URL", "https://base.manager.iblai.app"),
  wsUrl: () => getEnv("NEXT_PUBLIC_BASE_WS_URL", "wss://asgi.data.iblai.app"),
  agentUrl: () => getEnv("NEXT_PUBLIC_AGENT_URL", "http://localhost:3000"),
  mainTenantKey: () => getEnv("NEXT_PUBLIC_MAIN_TENANT_KEY", "{{ platform_key }}"),
  platform: () => getEnv("NEXT_PUBLIC_IBL_PLATFORM", "agent"),
  defaultAgentId: () => getEnv("NEXT_PUBLIC_DEFAULT_AGENT_ID", "{{ mentor_id if has_mentor_id else '' }}"),
  supportEmail: () => getEnv("NEXT_PUBLIC_SUPPORT_EMAIL", "support@ibl.ai"),
} as const;
