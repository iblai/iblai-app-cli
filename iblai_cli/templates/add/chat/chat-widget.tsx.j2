"use client";
{% raw %}
/**
 * IBL.ai Chat Widget
 *
 * A wrapper around the <mentor-ai> Web Component from @iblai/iblai-web-mentor.
 * The component renders an iframe to the hosted MentorAI platform and handles
 * authentication, WebSocket streaming, and all chat UI internally.
 *
 * Usage:
 *   import { ChatWidget } from "@/components/iblai/chat-widget";
 *   <ChatWidget mentorId="your-mentor-id" />
 *
 * Prerequisites:
 *   - pnpm add @iblai/iblai-web-mentor
 *   - Auth must be set up (iblai add auth or iblai startapp base)
 */

import { useEffect, useMemo, useRef, useState } from "react";
import config from "@/lib/iblai/config";

/** Read all IBL.ai auth tokens from localStorage and return as JSON string. */
function getAuthData(): string {
  if (typeof window === "undefined") return "";
  const tenant =
    localStorage.getItem("current_tenant") ??
    localStorage.getItem("tenant") ??
    "";

  // Resolve plain string tenant key from possible JSON object
  const resolveTenant = (raw: string | null): string => {
    if (!raw || raw === "[object Object]") return "";
    try {
      const p = JSON.parse(raw);
      if (typeof p === "string") return p;
      if (p?.key) return p.key;
    } catch { /* plain string */ }
    return raw;
  };

  return JSON.stringify({
    axd_token: localStorage.getItem("axd_token") ?? "",
    axd_token_expires: localStorage.getItem("axd_token_expires") ?? "",
    dm_token: localStorage.getItem("dm_token") ?? "",
    dm_token_expires: localStorage.getItem("dm_token_expires") ?? "",
    edx_jwt_token: localStorage.getItem("edx_jwt_token") ?? "",
    userData: localStorage.getItem("userData") ?? "",
    tenant: resolveTenant(tenant),
    tenants: localStorage.getItem("tenants") ?? "[]",
    current_tenant: resolveTenant(tenant),
  });
}

interface ChatWidgetProps {
  /** The mentor unique_id to chat with. */
  mentorId: string;
  /** Override the tenant key (defaults to localStorage / config value). */
  tenantKey?: string;
  /** Override the MentorAI platform URL (defaults to https://mentorai.{domain}). */
  mentorUrl?: string;
  /** Color theme. */
  theme?: "light" | "dark";
  /** Width of the chat widget. Number = pixels, string = CSS value. Default: 720. */
  width?: number | string;
  /** Height of the chat widget. Number = pixels, string = CSS value. Default: 600. */
  height?: number | string;
  /** Additional CSS class for the outer container. */
  className?: string;
}

export function ChatWidget({
  mentorId,
  tenantKey,
  mentorUrl,
  theme = "light",
  width = 720,
  height = 600,
  className,
}: ChatWidgetProps) {
  const [mounted, setMounted] = useState(false);
  const containerRef = useRef<HTMLDivElement>(null);

  // Import the web component on the client only (it needs the DOM).
  // .catch ensures mounted=true even if the import fails.
  useEffect(() => {
    import("@iblai/iblai-web-mentor")
      .then(() => setMounted(true))
      .catch((e) => {
        console.error("[IBL] Failed to load @iblai/iblai-web-mentor:", e);
        setMounted(true);
      });
  }, []);

  // After the web component mounts, set the iblData JS property on the
  // mentor-ai element so it has auth tokens ready when the iframe sends
  // its "ready" postMessage. Also add a fallback postMessage listener
  // that sends tokens directly to the iframe if the property was set
  // after the ready event already fired.
  useEffect(() => {
    if (!mounted) return;

    const authData = getAuthData();
    if (!authData) return;

    // 1. Set iblData as a JavaScript property (NOT setAttribute — the
    //    web component reads this.iblData, not an HTML attribute).
    const el = containerRef.current?.querySelector("mentor-ai") as any;
    if (el) {
      el.iblData = authData;
    }

    // 2. Fallback: listen for the iframe's "ready" postMessage and
    //    directly send tokens to the iframe's contentWindow.
    const handleMessage = (event: MessageEvent) => {
      if (!event.data?.ready) return;
      const mentorEl = containerRef.current?.querySelector("mentor-ai") as any;
      const iframe = mentorEl?.shadowRoot?.querySelector(
        "#ibl-chat-widget-container iframe",
      ) as HTMLIFrameElement | null;
      if (iframe?.contentWindow) {
        iframe.contentWindow.postMessage(JSON.parse(authData), "*");
      }
    };

    window.addEventListener("message", handleMessage);
    return () => window.removeEventListener("message", handleMessage);
  }, [mounted]);

  const resolvedTenant = useMemo(() => {
    if (tenantKey) return tenantKey;
    if (typeof window === "undefined") return "";
    for (const key of ["current_tenant", "tenant"]) {
      const stored = localStorage.getItem(key);
      if (stored && stored !== "[object Object]") {
        try {
          const parsed = JSON.parse(stored);
          if (typeof parsed === "string") return parsed;
          if (parsed?.key) return parsed.key;
        } catch {
          return stored;
        }
      }
    }
    return config.mainTenantKey();
  }, [tenantKey]);

  const resolvedWidth = typeof width === "number" ? `${width}px` : width;
  const resolvedHeight = typeof height === "number" ? `${height}px` : height;

  const resolvedMentorUrl = useMemo(() => {
    if (mentorUrl) return mentorUrl;
    const domain = config.platformBaseDomain?.() ?? "iblai.org";
    return `https://mentorai.${domain}`;
  }, [mentorUrl]);

  if (!mounted) {
    return (
      <div
        className={`flex items-center justify-center ${className ?? ""}`}
        style={{ width: resolvedWidth, height: resolvedHeight }}
      >
        <p className="text-sm text-gray-400">Loading chat…</p>
      </div>
    );
  }

  return (
    <div
      ref={containerRef}
      className={className ?? ""}
      style={{ width: resolvedWidth, height: resolvedHeight }}
    >
      {/* @ts-ignore — mentor-ai is a registered custom element */}
      <mentor-ai
        style={{ display: "block", width: resolvedWidth, height: resolvedHeight }}
        mentorurl={resolvedMentorUrl}
        authurl={config.authUrl()}
        lmsurl={config.lmsUrl()}
        tenant={resolvedTenant}
        mentor={mentorId}
        theme={theme}
        component="chat"
        authrelyonhost="true"
        extraparams="hide-navbar=1"
      />
    </div>
  );
}
{% endraw %}
