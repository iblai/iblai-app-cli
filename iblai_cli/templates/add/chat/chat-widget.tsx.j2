"use client";
{% raw %}
/**
 * IBL.ai Chat Widget
 *
 * Embeds the MentorAI platform in an iframe with auth tokens passed via
 * the ibl-data URL parameter. This avoids the web component's hardcoded
 * mode=anonymous which prevents the chat WebSocket session from starting.
 *
 * Usage:
 *   import { ChatWidget } from "@/components/iblai/chat-widget";
 *   <ChatWidget mentorId="your-mentor-id" />
 */

import { useEffect, useMemo, useRef, useState } from "react";
import config from "@/lib/iblai/config";

interface ChatWidgetProps {
  mentorId: string;
  tenantKey?: string;
  mentorUrl?: string;
  theme?: "light" | "dark";
  width?: number | string;
  height?: number | string;
  className?: string;
}

export function ChatWidget({
  mentorId,
  tenantKey,
  mentorUrl,
  theme = "light",
  width = 720,
  height = 600,
  className,
}: ChatWidgetProps) {
  const [tokensReady, setTokensReady] = useState(false);

  // Poll for dm_token — TenantProvider fetches it asynchronously.
  useEffect(() => {
    if (typeof window === "undefined") return;

    if (localStorage.getItem("dm_token")) {
      setTokensReady(true);
      return;
    }

    const interval = setInterval(() => {
      if (localStorage.getItem("dm_token")) {
        setTokensReady(true);
        clearInterval(interval);
      }
    }, 200);

    const timeout = setTimeout(() => {
      clearInterval(interval);
      setTokensReady(true);
    }, 20_000);

    return () => {
      clearInterval(interval);
      clearTimeout(timeout);
    };
  }, []);

  const resolvedTenant = useMemo(() => {
    if (tenantKey) return tenantKey;
    if (typeof window === "undefined") return "";
    for (const key of ["current_tenant", "tenant"]) {
      const stored = localStorage.getItem(key);
      if (stored && stored !== "[object Object]") {
        try {
          const parsed = JSON.parse(stored);
          if (typeof parsed === "string") return parsed;
          if (parsed?.key) return parsed.key;
        } catch {
          return stored;
        }
      }
    }
    return config.mainTenantKey();
  }, [tenantKey, tokensReady]);

  const resolvedWidth = typeof width === "number" ? `${width}px` : width;
  const resolvedHeight = typeof height === "number" ? `${height}px` : height;

  const resolvedMentorUrl = useMemo(() => {
    if (mentorUrl) return mentorUrl;
    const domain = config.platformBaseDomain?.() ?? "iblai.org";
    return `https://mentorai.${domain}`;
  }, [mentorUrl]);

  // Build the iframe src directly — bypasses the web component's hardcoded
  // mode=anonymous which prevents the WebSocket chat session from starting.
  const iframeSrc = useMemo(() => {
    if (!tokensReady || !resolvedTenant) return "";

    const params = new URLSearchParams({
      embed: "true",
      theme,
      "hide-navbar": "1",
    });

    // Pass auth tokens so the MentorAI app authenticates on first load.
    if (typeof window !== "undefined") {
      const resolveTenantStr = (raw: string | null): string => {
        if (!raw || raw === "[object Object]") return "";
        try {
          const p = JSON.parse(raw);
          if (typeof p === "string") return p;
          if (p?.key) return p.key;
        } catch { /* plain string */ }
        return raw;
      };

      const iblData = JSON.stringify({
        axd_token: localStorage.getItem("axd_token") ?? "",
        axd_token_expires: localStorage.getItem("axd_token_expires") ?? "",
        dm_token: localStorage.getItem("dm_token") ?? "",
        dm_token_expires: localStorage.getItem("dm_token_expires") ?? "",
        edx_jwt_token: localStorage.getItem("edx_jwt_token") ?? "",
        userData: localStorage.getItem("userData") ?? "",
        tenant: resolvedTenant,
        tenants: localStorage.getItem("tenants") ?? "[]",
        current_tenant: resolvedTenant,
      });
      params.set("ibl-data", iblData);
    }

    return `${resolvedMentorUrl}/platform/${resolvedTenant}/${mentorId}/?${params.toString()}`;
  }, [tokensReady, resolvedTenant, resolvedMentorUrl, mentorId, theme]);

  if (!tokensReady || !iframeSrc) {
    return (
      <div
        className={`flex items-center justify-center ${className ?? ""}`}
        style={{ width: resolvedWidth, height: resolvedHeight }}
      >
        <p className="text-sm text-gray-400">Loading chat…</p>
      </div>
    );
  }

  return (
    <iframe
      src={iframeSrc}
      className={className ?? ""}
      style={{
        width: resolvedWidth,
        height: resolvedHeight,
        border: "none",
        display: "block",
      }}
      allow="microphone; camera"
      title="IBL.ai Chat"
    />
  );
}
