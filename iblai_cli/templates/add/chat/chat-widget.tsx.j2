"use client";
{% raw %}
/**
 * IBL.ai Chat Widget
 *
 * A wrapper around the <mentor-ai> Web Component from @iblai/iblai-web-mentor.
 * The component renders an iframe to the hosted MentorAI platform and handles
 * authentication, WebSocket streaming, and all chat UI internally.
 *
 * Usage:
 *   import { ChatWidget } from "@/components/iblai/chat-widget";
 *   <ChatWidget mentorId="your-mentor-id" />
 *
 * Prerequisites:
 *   - pnpm add @iblai/iblai-web-mentor
 *   - Auth must be set up (iblai add auth or iblai startapp base)
 */

import { useEffect, useMemo, useRef, useState } from "react";
import config from "@/lib/iblai/config";

interface ChatWidgetProps {
  /** The mentor unique_id to chat with. */
  mentorId: string;
  /** Override the tenant key (defaults to localStorage / config value). */
  tenantKey?: string;
  /** Override the MentorAI platform URL (defaults to https://mentorai.{domain}). */
  mentorUrl?: string;
  /** Color theme. */
  theme?: "light" | "dark";
  /** Width of the chat widget. Number = pixels, string = CSS value. Default: 720. */
  width?: number | string;
  /** Height of the chat widget. Number = pixels, string = CSS value. Default: 600. */
  height?: number | string;
  /** Additional CSS class for the outer container. */
  className?: string;
}

export function ChatWidget({
  mentorId,
  tenantKey,
  mentorUrl,
  theme = "light",
  width = 720,
  height = 600,
  className,
}: ChatWidgetProps) {
  const [mounted, setMounted] = useState(false);
  const [tokensReady, setTokensReady] = useState(false);
  const containerRef = useRef<HTMLDivElement>(null);

  // Import the web component on the client only (it needs the DOM).
  useEffect(() => {
    import("@iblai/iblai-web-mentor")
      .then(() => setMounted(true))
      .catch((e) => {
        console.error("[IBL] Failed to load @iblai/iblai-web-mentor:", e);
        setMounted(true);
      });
  }, []);

  // Poll for dm_token — TenantProvider fetches it asynchronously.
  // Only render <mentor-ai> once tokens are present so the iframe URL
  // includes valid ibl-data from the first request.
  useEffect(() => {
    if (typeof window === "undefined") return;

    if (localStorage.getItem("dm_token")) {
      setTokensReady(true);
      return;
    }

    const interval = setInterval(() => {
      if (localStorage.getItem("dm_token")) {
        setTokensReady(true);
        clearInterval(interval);
      }
    }, 200);

    const timeout = setTimeout(() => {
      clearInterval(interval);
      console.warn("[IBL ChatWidget] dm_token not found after 20s — rendering anyway");
      setTokensReady(true);
    }, 20_000);

    return () => {
      clearInterval(interval);
      clearTimeout(timeout);
    };
  }, []);

  const resolvedTenant = useMemo(() => {
    if (tenantKey) return tenantKey;
    if (typeof window === "undefined") return "";
    for (const key of ["current_tenant", "tenant"]) {
      const stored = localStorage.getItem(key);
      if (stored && stored !== "[object Object]") {
        try {
          const parsed = JSON.parse(stored);
          if (typeof parsed === "string") return parsed;
          if (parsed?.key) return parsed.key;
        } catch {
          return stored;
        }
      }
    }
    return config.mainTenantKey();
  }, [tenantKey, tokensReady]);

  const resolvedWidth = typeof width === "number" ? `${width}px` : width;
  const resolvedHeight = typeof height === "number" ? `${height}px` : height;

  const resolvedMentorUrl = useMemo(() => {
    if (mentorUrl) return mentorUrl;
    const domain = config.platformBaseDomain?.() ?? "iblai.org";
    return `https://mentorai.${domain}`;
  }, [mentorUrl]);

  // Build ibl-data query param so the MentorAI iframe loads pre-authenticated
  // on the first request. The MentorAI app reads ibl-data from its own URL
  // query params, sets its auth state, and avoids cross-origin issues entirely.
  // NOTE: resolvedTenant is used (not localStorage) to ensure the tenant key
  // is always valid at param construction time.
  const iblDataParam = useMemo(() => {
    if (!tokensReady || !resolvedTenant || typeof window === "undefined") return "";

    const data = JSON.stringify({
      axd_token: localStorage.getItem("axd_token") ?? "",
      axd_token_expires: localStorage.getItem("axd_token_expires") ?? "",
      dm_token: localStorage.getItem("dm_token") ?? "",
      dm_token_expires: localStorage.getItem("dm_token_expires") ?? "",
      edx_jwt_token: localStorage.getItem("edx_jwt_token") ?? "",
      userData: localStorage.getItem("userData") ?? "",
      tenant: resolvedTenant,
      tenants: localStorage.getItem("tenants") ?? "[]",
      current_tenant: resolvedTenant,
    });

    return encodeURIComponent(data);
  }, [tokensReady, resolvedTenant]);

  // Create the mentor-ai element imperatively once tokens are ready.
  // Tokens are passed via extraparams as ibl-data= in the iframe URL,
  // so the MentorAI app authenticates on the very first page load.
  useEffect(() => {
    if (!mounted || !tokensReady || !containerRef.current) return;

    const el = document.createElement("mentor-ai") as any;

    const extraParams = iblDataParam
      ? `hide-navbar=1&ibl-data=${iblDataParam}`
      : "hide-navbar=1";

    el.setAttribute("mentorurl", resolvedMentorUrl);
    el.setAttribute("authurl", config.authUrl());
    el.setAttribute("lmsurl", config.lmsUrl());
    el.setAttribute("tenant", resolvedTenant);
    el.setAttribute("mentor", mentorId);
    el.setAttribute("theme", theme);
    el.setAttribute("component", "chat");
    el.setAttribute("authrelyonhost", "true");
    el.setAttribute("extraparams", extraParams);
    el.style.cssText = `display:block;width:${resolvedWidth};height:${resolvedHeight}`;

    containerRef.current.appendChild(el);

    return () => {
      el.remove();
    };
  }, [mounted, tokensReady, iblDataParam, resolvedMentorUrl, resolvedTenant, mentorId, theme, resolvedWidth, resolvedHeight]);

  return (
    <div
      ref={containerRef}
      className={className ?? ""}
      style={{ width: resolvedWidth, height: resolvedHeight }}
    >
      {(!mounted || !tokensReady) && (
        <div className="flex h-full w-full items-center justify-center">
          <p className="text-sm text-gray-400">Loading chat…</p>
        </div>
      )}
    </div>
  );
}
{% endraw %}
