/**
 * IBL.ai runtime configuration.
 *
 * Reads values from NEXT_PUBLIC_* environment variables (build‑time) and
 * falls back to window.__env (injected at runtime via public/env.js).
 */

declare global {
  interface Window {
    __env?: Record<string, string>;
  }
}

function env(key: string, fallback = ""): string {
  if (typeof window !== "undefined" && window.__env?.[key]) {
    return window.__env[key];
  }
  return process.env[key] ?? fallback;
}

const config = {
  authUrl: () => env("NEXT_PUBLIC_AUTH_URL", "https://auth.iblai.org"),
  dmUrl: () => env("NEXT_PUBLIC_DM_URL", "https://base.manager.iblai.app"),
  lmsUrl: () => env("NEXT_PUBLIC_LMS_URL", "https://learn.iblai.app"),
  wsUrl: () => env("NEXT_PUBLIC_BASE_WS_URL", "wss://asgi.data.iblai.org"),
  baseWsUrl: () => env("NEXT_PUBLIC_BASE_WS_URL", "wss://asgi.data.iblai.org"),
};

export default config;
