"use client";
{% raw %}
import { useEffect, useState } from "react";
import { useRouter } from "next/navigation";
import { Profile } from "@iblai/iblai-js/web-containers";
import { config } from "@/lib/config";

function resolveTenantKey(raw: string | null): string {
  if (!raw || raw === "[object Object]") return "";
  try {
    const p = JSON.parse(raw);
    if (typeof p === "string") return p;
    if (p?.key) return p.key;
  } catch { /* plain string */ }
  return raw;
}

export default function ProfilePage() {
  const router = useRouter();
  const [username, setUsername] = useState("");
  const [tenantKey, setTenantKey] = useState("");
  const [ready, setReady] = useState(false);

  // Read auth data from localStorage after client-side mount.
  // Using useState + useEffect (not useMemo) avoids SSR hydration
  // mismatches and ensures we read after AuthProvider has stored tokens.
  useEffect(() => {
    // username
    try {
      const raw = localStorage.getItem("userData");
      if (raw) {
        const parsed = JSON.parse(raw);
        setUsername(parsed.user_nicename ?? parsed.username ?? "");
      }
    } catch { /* ignore */ }

    // tenant key
    const stored =
      localStorage.getItem("current_tenant") ??
      localStorage.getItem("tenant");
    const resolved = resolveTenantKey(stored) || config.mainTenantKey();
    setTenantKey(resolved);

    setReady(true);
  }, []);

  if (!ready || !username || !tenantKey) {
    return (
      <div
        style={{
          height: "100vh",
          width: "100vw",
          display: "flex",
          alignItems: "center",
          justifyContent: "center",
        }}
      >
        <p style={{ color: "#9ca3af", fontSize: "0.875rem" }}>
          Loading profile…
        </p>
      </div>
    );
  }

  return (
    <div
      style={{
        height: "100vh",
        width: "100vw",
        overflow: "auto",
      }}
    >
      <Profile
        tenant={tenantKey}
        username={username}
        onClose={() => router.push("/")}
        customization={{
          showUsernameField: true,
          showPlatformName: true,
          useGravatarPicFallback: true,
        }}
        targetTab="basic"
      />
    </div>
  );
}
{% endraw %}
