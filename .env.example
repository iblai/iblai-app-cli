# IBL.ai CLI Configuration
# Copy to .env and customize, or use .env.{stage} for stage-specific overrides.
# Set DEV_STAGE=production to auto-load .env.production, etc.
#
# Resolution priority (highest wins):
#   CLI flags > System env vars > .env.{DEV_STAGE} > .env > interactive prompts

# App configuration
IBLAI_PLATFORM_KEY=
IBLAI_APP_NAME=
IBLAI_AGENT_ID=
IBLAI_OUTPUT_DIR=.

# AI configuration
IBLAI_AI_PROVIDER=          # openai or anthropic
IBLAI_AI_MODEL=             # e.g., claude-sonnet-4-20250514, gpt-4-turbo-preview
IBLAI_AI_TEMPERATURE=       # 0.0-2.0 (default: 0.3 for openai)
IBLAI_AI_MAX_TOKENS=        # e.g., 4096, 8192
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
IBLAI_PROMPT=
