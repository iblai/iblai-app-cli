import { type ClassValue, clsx } from "clsx";
import { twMerge } from "tailwind-merge";
import { config } from "./config";

export function cn(...inputs: ClassValue[]) {
  return twMerge(clsx(inputs));
}

/**
 * Redirect to the Auth SPA for login/logout
 */
export function redirectToAuthSpa(
  redirectTo?: string,
  platformKey?: string,
  logout?: boolean,
  saveRedirect = true
): void {
  const AUTH_URL = config.authUrl();
  const AGENT_URL = config.agentUrl();
  const tenant = platformKey || config.mainTenantKey();

  // Clear local storage on logout
  if (logout) {
    localStorage.clear();
  }

  // Save redirect path
  if (saveRedirect && !logout) {
    const currentPath = window.location.pathname + window.location.search;
    localStorage.setItem("redirect_to", currentPath);
  }

  // Build auth URL manually to avoid URLSearchParams percent-encoding
  let authUrl = `${AUTH_URL}/login?app=agent&redirect-to=${redirectTo || AGENT_URL}`;
  if (tenant) authUrl += `&tenant=${encodeURIComponent(tenant)}`;
  if (logout) authUrl += "&logout=1";

  window.location.href = authUrl;
}
