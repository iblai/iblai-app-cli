# ibl.ai Platform Configuration
# Consolidated API (recommended) — LMS, DM, AXD derived as path prefixes
NEXT_PUBLIC_API_BASE_URL=https://api.iblai.org
NEXT_PUBLIC_AUTH_URL=https://auth.iblai.org
NEXT_PUBLIC_BASE_WS_URL=wss://asgi.data.iblai.org
NEXT_PUBLIC_PLATFORM_BASE_DOMAIN=iblai.org

# Or set individual URLs (overrides consolidated):
# NEXT_PUBLIC_LMS_URL=https://learn.iblai.org
# NEXT_PUBLIC_DM_URL=https://base.manager.iblai.org
# NEXT_PUBLIC_AXD_URL=https://base.manager.iblai.org

# App Configuration
NEXT_PUBLIC_MAIN_TENANT_KEY={{ platform_key }}
NEXT_PUBLIC_IBL_PLATFORM=agent
NEXT_PUBLIC_AGENT_URL=http://localhost:3000
{% if has_mentor_id %}
NEXT_PUBLIC_DEFAULT_AGENT_ID={{ mentor_id }}
{% endif %}

# Support
NEXT_PUBLIC_SUPPORT_EMAIL=support@ibl.ai
